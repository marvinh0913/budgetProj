{
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "chart.js": "^4.5.1",
    "pyodide": "^314.0.2",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "fetch-rates": "node src/services/fetchRates.js",
    "build": "npm run fetch-rates && mkdir -p public/src/python && cp src/python/*.py public/src/python/ && vite build",
    "preview": "vite preview",
    "lint": "eslint src/**/*.{js,jsx} --ignore-pattern src/services/fetchRates.js --no-warn-ignored",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "deploy": "npm run build && gh-pages -d dist"
  }
